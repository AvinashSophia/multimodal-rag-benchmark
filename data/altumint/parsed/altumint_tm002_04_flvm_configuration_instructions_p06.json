        "b": 583.8574177085038,
        "coord_origin": "BOTTOMLEFT"
      }
    },
    {
      "text": "Confirm you can connect and login to the web relay at You will see the login screen below: http://192.168.0.200:5000/",
      "label": "list_item",
      "bbox": {
        "l": 57.754685093554684,
        "t": 573.1046871068079,
