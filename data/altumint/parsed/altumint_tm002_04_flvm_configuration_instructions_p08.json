        "coord_origin": "BOTTOMLEFT"
      }
    },
    {
      "text": "Under Battery Preset, tap Select Preset, scroll down to select Smart Lithium (LiFePO4) and tap OK.",
      "label": "list_item",
      "bbox": {
        "l": 57.754685093554684,
        "t": 458.86445186681703,
        "r": 536.8428737755461,
        "b": 427.77835892590156,
        "coord_origin": "BOTTOMLEFT"
      }
    },
    {
      "text": "Return to the Settings screen. Select Load Output .",
