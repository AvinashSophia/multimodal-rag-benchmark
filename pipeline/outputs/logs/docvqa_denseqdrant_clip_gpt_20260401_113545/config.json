{
  "dataset": {
    "name": "docvqa",
    "split": "validation",
    "max_samples": 5,
    "data_dir": "data/"
  },
  "retrieval": {
    "text": {
      "method": "dense_qdrant",
      "model_name": "BAAI/bge-large-en-v1.5",
      "top_k": 5,
      "qdrant": {
        "path": "pipeline/outputs/qdrant_store",
        "collection": "dense_text"
      },
      "elasticsearch": {
        "url": "http://localhost:9200",
        "index": "bm25_text",
        "username": "",
        "password": "",
        "ca_cert": ""
      }
    },
    "image": {
      "method": "clip",
      "model_name": "ViT-B-32",
      "top_k": 5,
      "fusion_alpha": 0.5,
      "qdrant": {
        "path": "pipeline/outputs/qdrant_store",
        "collection": "clip_images"
      }
    }
  },
  "model": {
    "name": "gpt",
    "gpt": {
      "model_id": "gpt-4o",
      "max_tokens": 512,
      "temperature": 0.0
    },
    "gemini": {
      "model_id": "gemini-2.5-pro",
      "max_tokens": 512,
      "temperature": 0.0
    },
    "gemini_vertex": {
      "project_id": "way-back-home-487418",
      "location": "us-central1",
      "model_id": "gemini-2.5-flash-lite-preview-09-2025",
      "max_tokens": 512,
      "temperature": 0.0
    },
    "qwen_vl": {
      "model_id": "Qwen/Qwen2.5-VL-7B-Instruct",
      "max_tokens": 512
    }
  },
  "evaluation": {
    "backend": "production",
    "retrieval_metrics": [
      "recall_at_k",
      "mrr",
      "ndcg"
    ],
    "answer_metrics": [
      "exact_match",
      "f1"
    ],
    "grounding_metrics": [
      "faithfulness",
      "attribution_accuracy"
    ],
    "multimodal_metrics": [
      "vqa_accuracy",
      "cross_modal_consistency"
    ],
    "recall_k_values": [
      5
    ]
  },
  "output": {
    "dir": "pipeline/outputs",
    "log_dir": "pipeline/outputs/logs",
    "save_retrieved_context": true,
    "save_attribution": true
  },
  "run": {
    "seed": 42,
    "batch_size": 16,
    "num_workers": 4
  }
}