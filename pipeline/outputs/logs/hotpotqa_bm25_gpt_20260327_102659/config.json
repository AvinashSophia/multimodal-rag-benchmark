{
  "dataset": {
    "name": "hotpotqa",
    "split": "validation",
    "max_samples": 5,
    "data_dir": "data/"
  },
  "retrieval": {
    "text": {
      "method": "bm25",
      "model_name": "BAAI/bge-large-en-v1.5",
      "top_k": 5
    },
    "image": {
      "method": "clip",
      "model_name": "ViT-B-32",
      "top_k": 5
    }
  },
  "model": {
    "name": "gpt",
    "gpt": {
      "model_id": "gpt-4o",
      "max_tokens": 512,
      "temperature": 0.0
    },
    "gemini": {
      "model_id": "gemini-2.0-flash",
      "max_tokens": 512,
      "temperature": 0.0
    },
    "qwen_vl": {
      "model_id": "Qwen/Qwen2.5-VL-7B-Instruct",
      "max_tokens": 512
    }
  },
  "evaluation": {
    "retrieval_metrics": [
      "recall_at_k",
      "mrr",
      "ndcg"
    ],
    "answer_metrics": [
      "exact_match",
      "f1"
    ],
    "grounding_metrics": [
      "faithfulness",
      "attribution_accuracy"
    ],
    "multimodal_metrics": [
      "vqa_accuracy",
      "cross_modal_consistency"
    ],
    "recall_k_values": [
      1,
      3,
      5,
      10
    ]
  },
  "output": {
    "dir": "pipeline/outputs",
    "log_dir": "pipeline/outputs/logs",
    "save_retrieved_context": true,
    "save_attribution": true
  },
  "run": {
    "seed": 42,
    "batch_size": 16,
    "num_workers": 4
  }
}