    "new_string": "    def run_model(\n        self,\n        question: str,\n        text_context: List[str],\n        image_context: List[Any],\n        text_ids: Optional[List[str]] = None,\n        image_ids: Optional[List[str]] = None,\n    ) -> ModelResult:",
