    "new_string": "    def retrieve(self, query: str, top_k: int = 5, query_image: Optional[Any] = None) -> RetrievalResult:\n        \"\"\"Retrieve top-k chunks by semantic similarity from Qdrant. query_image is ignored.\"\"\"",
