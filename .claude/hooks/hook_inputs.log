    "new_string": "        self.model_name = text_cfg.get(\"model_name\", \"BAAI/bge-large-en-v1.5\")\n        dataset_name = config.get(\"dataset\", {}).get(\"name\", \"default\")\n        self.collection = f\"{qdrant_cfg.get('collection', 'dense_text')}_{dataset_name}\"",
    "replace_all": false
