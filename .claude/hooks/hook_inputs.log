ks=[self.corpus[i] for i in top_indices],\n            text_scores=[float(scores[i]) for i in top_indices],\n            text_ids=[self.corpus_ids[i] for i in top_indices],\n            images=[],\n            image_scores=[],\n            image_ids=[],\n            metadata={\"method\": \"dense\", \"model\": getattr(self.model, \"_model_card_data\", {}).get(\"model_name\", self.model.__class__.__name__), \"query\": query},\n        )\n",
