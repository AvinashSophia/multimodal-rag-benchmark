    "old_string": "    def retrieve(self, query: str, top_k: int = 5) -> RetrievalResult:\n        \"\"\"Retrieve top-k images matching the text query using CLIP.\"\"\"\n        import torch\n        with torch.no_grad():\n            text_tokens = self.tokenizer([query])\n            text_embedding = self.model.encode_text(text_tokens)\n            text_embedding = text_embedding / text_embedding.norm(dim=-1, keepdim=True)\n            query_vector = text_embedding.cpu().numpy().flatten().tolist()\n\n        hits: List[ScoredPoint] = self.qdrant.query_points(\n            collection_name=self.collection,\n            query=query_vector,\n            limit=top_k,\n        ).points\n\n        # Keep only hits whose image is in the store — filter ids, images, scores together\n        results = [\n            (hit.payload[\"image_id\"], self._image_store[hit.payload[\"image_id\"]], hit.score)\n            for hit in hits\n            if hit.payload is not None and hit.payload[\"image_id\"] in self._image_store\n        ]\n        image_ids   = [r[0] for r in results]\n        images      = [r[1] for r in results]\n        image_scores = [r[2] for r in results]\n\n        return RetrievalResult(\n            text_chunks=[],\n            text_scores=[],\n            text_ids=[],\n            images=images,\n            image_scores=image_scores,\n            image_ids=image_ids,\n            metadata={\"method\": \"clip_qdrant\", \"model\": self.model_name, \"query\": query},\n        )",
