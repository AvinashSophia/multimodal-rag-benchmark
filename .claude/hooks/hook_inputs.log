  "tool_input": {
    "file_path": "/Users/avinashbolleddula/Documents/multimodal-rag-benchmark/pipeline/models/qwen_vl_aws.py",
    "content": "\"\"\"Qwen-VL via AWS SageMaker endpoint.\"\"\"\n\nimport re\nimport json\nimport base64\nfrom io import BytesIO\nfrom typing import Dict, List, Any, Optional\nfrom PIL import Image\nfrom pipeline.models.base import BaseModel, register_model\nfrom pipeline.utils import ModelResult\n\n\n@register_model(\"qwen_vl_aws\")\nclass QwenVLAWSModel(BaseModel):\n    \"\"\"Qwen-VL wrapper that calls a company-hosted AWS SageMaker endpoint.\n\n    Use this instead of QwenVLModel when you don't have a local GPU.\n\n    Requires:\n        - AWS credentials configured via `aws configure` or environment variables:\n            AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_DEFAULT_REGION\n        - A SageMaker endpoint running a Qwen-VL model\n\n    Config keys (under model.qwen_vl_aws):\n        endpoint_name: SageMaker endpoint name (required)\n        region:        AWS region (default: us-east-1)\n        max_tokens:    Max output tokens (default: 512)\n    \"\"\"\n\n    def __init__(self, config: Dict[str, Any]):\n        super().__init__(config)\n        import boto3\n\n        aws_cfg = config[\"model\"].get(\"qwen_vl_aws\", {})\n        self.endpoint_name = aws_cfg.get(\"endpoint_name\", \"\")\n        self.region = aws_cfg.get(\"region\", \"us-east-1\")\n        self.max_tokens = aws_cfg.get(\"max_tokens\", 512)\n        self.model_id = f\"sagemaker::{self.endpoint_name}\"\n\n        self.client = boto3.client(\"sagemaker-runtime\", region_name=self.region)\n\n    def _image_to_base64(self, img: Any) -> str:\n        \"\"\"Convert PIL Image to base64 PNG string.\"\"\"\n        if isinstance(img, str):\n            img = Image.open(img)\n        buf = BytesIO()\n        img.convert(\"RGB\").save(buf, format=\"PNG\")\n        return base64.b64encode(buf.getvalue()).decode(\"utf-8\")\n\n    def _build_prompt(self, question: str, text_context: List[str], text_ids: Optional[List[str]] = None, has_images: bool = False) -> str:\n        \"\"\"Build the text portion of the prompt. Images are interleaved in run_model.\"\"\"\n        has_text = len(text_context) > 0\n\n        citation_instruction = (\n            \"Provide a concise answer with no inline citations or brackets.\\n\"\n            \"On a new line, list ONLY the exact source IDs you used, in this format:\\n\"\n            \"Sources: [id1, id2, ...]\"\n        )\n\n        if has_text:\n            if text_ids:\n                context_str = \"\\n\\n\".join(\n                    [f\"[{text_ids[i]}]: {chunk}\" for i, chunk in enumerate(text_context)]\n                )\n            else:\n                context_str = \"\\n\\n\".join(\n                    [f\"[doc_{i}]: {chunk}\" for i, chunk in enumerate(text_context)]\n                )\n\n        if has_text and has_images:\n            return (\n                f\"Answer the following question based on the provided text and labeled images below.\\n\\n\"\n                f\"Text Context:\\n{context_str}\\n\\n\"\n                f\"Question: {question}\\n\\n\"\n                f\"Each image is preceded by its ID label (e.g. [image_id]:).\\n\\n\"\n                f\"{citation_instruction}\"\n            )\n        elif has_images:\n            return (\n                f\"Answer the following question based on the labeled images below.\\n\\n\"\n                f\"Question: {question}\\n\\n\"\n                f\"Each image is preceded by its ID label (e.g. [image_id]:).\\n\\n\"\n                f\"{citation_instruction}\"\n            )\n        else:\n            return (\n                f\"Answer the following question based on the provided context.\\n\\n\"\n                f\"Context:\\n{context_str}\\n\\n\"\n                f\"Question: {question}\\n\\n\"\n                f\"{citation_instruction}\"\n            )\n\n    def run_model(\n        self,\n        question: str,\n        text_context: List[str],\n        image_context: List[Any],\n        text_ids: Optional[List[str]] = None,\n        image_ids: Optional[List[str]] = None,\n    ) -> ModelResult:\n        \"\"\"Call the SageMaker endpoint with text and image context.\"\"\"\n        prompt = self._build_prompt(question, text_context, text_ids=text_ids, has_images=bool(image_context))\n\n        # Build messages in OpenAI-compatible format (standard for SageMaker Qwen deployments)\n        content: List[Dict[str, Any]] = []\n        for i, img in enumerate(image_context):\n            img_id = image_ids[i] if image_ids and i < len(image_ids) else f\"image_{i}\"\n            b64 = self._image_to_base64(img)\n            content.append({\"type\": \"text\", \"text\": f\"[{img_id}]:\"})\n            content.append({\n                \"type\": \"image_url\",\n                \"image_url\": {\"url\": f\"data:image/png;base64,{b64}\"},\n            })\n        content.append({\"type\": \"text\", \"text\": prompt})\n\n        payload = {\n            \"messages\": [{\"role\": \"user\", \"content\": content}],\n            \"max_tokens\": self.max_tokens,\n            \"temperature\": 0.0,\n        }\n\n        response = self.client.invoke_endpoint(\n            EndpointName=self.endpoint_name,\n            ContentType=\"application/json\",\n            Body=json.dumps(payload),\n        )\n\n        result = json.loads(response[\"Body\"].read().decode(\"utf-8\"))\n\n        # Handle both OpenAI-compatible and plain text response formats\n        if \"choices\" in result:\n            answer = result[\"choices\"][0][\"message\"][\"content\"]\n        elif \"generated_text\" in result:\n            answer = result[\"generated_text\"]\n        elif \"outputs\" in result:\n            answer = result[\"outputs\"][0][\"text\"]\n        else:\n            answer = str(result)\n\n        # Parse cited source IDs — handles: Sources: [id1, id2], [id1], [id2], or id1, id2\n        sources: List[str] = []\n        source_match = re.search(r'[Ss]ources:\\s*(.+)', answer)\n        if source_match:\n            raw = source_match.group(1).replace('[', '').replace(']', '')\n            sources = [s.strip() for s in raw.split(',') if s.strip()]\n\n        # Strip the entire Sources line so answer metrics aren't polluted by it\n        clean_answer = re.sub(r'\\s*[Ss]ources:\\s*.+', '', answer).strip()\n\n        return ModelResult(\n            answer=clean_answer,\n            sources=sources,\n            raw_response=answer,\n            metadata={\"model\": self.model_id, \"endpoint\": self.endpoint_name},\n        )\n"
  },
